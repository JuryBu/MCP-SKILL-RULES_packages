# Test/Review reports (council review 历史报告,可再生)
tests/reports/
tests/council/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Temp / backup files
*.tmp
*.bak
*.orig

# Env files (如果以后有的话)
.env
.env.local
.env.*.local
