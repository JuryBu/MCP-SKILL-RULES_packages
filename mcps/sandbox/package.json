{
    "name": "sandbox-mcp-server",
    "version": "1.13.7",
    "description": "MCP Server - 代码执行沙箱，支持硬超时、内存限制、持久会话、并行执行、GPU/CUDA",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "clean": "rimraf dist",
        "test:exec-mutex": "npm run build && node tests/exec_mutex.test.mjs",
        "test:batch-mutex": "npm run build && node tests/batch_mutex.test.mjs",
        "test:council-antigravity": "npm run build && node tests/council_antigravity.test.mjs",
        "test:council-missing-image": "npm run build && node tests/council_missing_image.test.mjs",
        "test:exec-stderr-tempfile": "npm run build && node tests/exec_stderr_tempfile.test.mjs",
        "test:launch-cwd": "npm run build && node tests/launch_cwd.test.mjs",
        "test:session-memory-reservation": "npm run build && node tests/session_memory_reservation.test.mjs",
        "test:smart-search-rg": "npm run build && node tests/smart_search_rg.test.mjs",
        "test:background-abort": "npm run build && node tests/background_abort.test.mjs",
        "test:ssrf-redirect": "npm run build && node tests/ssrf_redirect.test.mjs",
        "test:shell-injection": "npm run build && node tests/shell_injection.test.mjs"
    },
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.6.1",
        "fuse.js": "^7.3.0",
        "pidusage": "^3.0.2",
        "web-tree-sitter": "^0.26.8",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "@types/pidusage": "^2.0.5",
        "tree-sitter-cli": "^0.26.8",
        "tree-sitter-javascript": "^0.25.0",
        "tree-sitter-python": "^0.25.0",
        "tree-sitter-typescript": "^0.23.2",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    }
}
