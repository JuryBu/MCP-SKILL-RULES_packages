{
  "name": "memory-store-mcp-server",
  "version": "1.21.1",
  "description": "MCP Server - AI 主动记忆管理系统，支持多工作区、冷热分层、批量操作、四数据链路对话原文读取、Auto Summary 双轨制、黄金片段提取、进程生命周期容错",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rimraf dist",
    "test:portable": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "fuse.js": "^7.0.0",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
